{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=MailService;TrustServerCertificate=True;MultipleActiveResultSets=true;Integrated Security=SSPI;"
  },
  "FileStorage": {
    "Provider": "Local",
    "UseProjectDirectory": true,
    "RelativePath": "App_Data/Attachments"
  },
  "Jwt": {
    "Secret": "SUPER_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS_DEV_ONLY",
    "Issuer": "MailCore",
    "Audience": "MailCore",
    "ExpiryMinutes": 60
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "http://localhost:5173" ]
  }
}
